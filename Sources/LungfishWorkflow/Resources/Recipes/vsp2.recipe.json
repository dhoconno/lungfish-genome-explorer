{
    "formatVersion": 1,
    "id": "vsp2-target-enrichment",
    "name": "VSP2 Target Enrichment",
    "description": "Optimized for VSP2 short-insert viral enrichment: dedup, trim, scrub human, merge, length filter.",
    "author": "Lungfish Built-in",
    "tags": ["illumina", "vsp2", "viral", "paired-end", "target-enrichment"],
    "platforms": ["illumina"],
    "requiredInput": "paired",
    "qualityBinning": "illumina4",
    "steps": [
        { "type": "fastp-dedup", "label": "Remove PCR duplicates" },
        { "type": "fastp-trim", "label": "Adapter + quality trim", "params": { "detectAdapter": true, "quality": 15, "window": 5, "cutMode": "right" } },
        { "type": "deacon-scrub", "label": "Remove human reads", "params": { "database": "deacon-panhuman" } },
        { "type": "fastp-merge", "label": "Merge overlapping pairs", "params": { "minOverlap": 15 } },
        { "type": "seqkit-length-filter", "label": "Remove short reads", "params": { "minLength": 50 } }
    ]
}
